{
  "title": "ADS-B Trace Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "icao": {
      "title": "ICAO24",
      "type": "string",
      "description": "Aircraft ICAO24 hex ID, e.g. 3c4598.",
      "editor": "textfield"
    },
    "icaos": {
      "title": "ICAO24 List",
      "type": "array",
      "description": "Batch mode: multiple ICAO24 values for parallel fetch.",
      "editor": "stringList",
      "prefill": [
        "3c4598",
        "a1d8bf"
      ]
    },
    "mode": {
      "title": "Trace Mode",
      "type": "string",
      "description": "Fetch full or recent trace.",
      "default": "full",
      "enum": [
        "full",
        "recent"
      ],
      "editor": "select"
    },
    "includePoints": {
      "title": "Include Full Points",
      "type": "boolean",
      "description": "If disabled, returns only meta + latest for faster responses.",
      "default": false,
      "editor": "checkbox"
    },
    "maxPoints": {
      "title": "Max Points",
      "type": "integer",
      "description": "Optional limit for returned points (latest N points).",
      "minimum": 1,
      "editor": "number"
    },
    "windows": {
      "title": "Trend Windows",
      "type": "array",
      "description": "Window trends for 15m/1h/6h.",
      "editor": "stringList",
      "prefill": [
        "15m",
        "1h",
        "6h"
      ]
    },
    "concurrency": {
      "title": "Batch Concurrency",
      "type": "integer",
      "description": "Maximum parallel fetch jobs (1-20).",
      "default": 5,
      "minimum": 1,
      "maximum": 20,
      "editor": "number"
    },
    "region": {
      "title": "Region Filter",
      "type": "object",
      "description": "Optional bounding box for regional aggregation.",
      "editor": "json"
    },
    "warmup": {
      "title": "Warmup Landing Page",
      "type": "boolean",
      "description": "Open the landing page before fetching trace.",
      "default": true,
      "editor": "checkbox"
    }
  }
}
